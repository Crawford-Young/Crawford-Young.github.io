# GitHub Personal Access Token
# Create at https://github.com/settings/tokens
# No scopes required — zero-scope tokens work for public data and raise rate limit to 5000 req/hr
GITHUB_TOKEN=

# Sentry — error monitoring
# DSN found at https://sentry.io/settings/projects/javascript-nextjs/keys/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Auth token for source map uploads — https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
